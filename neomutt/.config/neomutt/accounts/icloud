# iCloud account settings
set realname  = "Chao Dai"
set from      = "bajia@me.com"
set status_format = " iCloud  ·  %f  ·  %r%m msgs%?n?  %n new?%?d?  %d del?%?t?  %t tag? %>  %?p?%p postponed  ? "

set folder    = "~/Mails/iCloud"
set spoolfile = "+INBOX"
set postponed = "+Drafts"
set record    = "+Sent"
set trash     = "+Trash"

set sendmail = "msmtp --account=icloud"

unmailboxes *
named-mailboxes "iCloud/INBOX"   +INBOX
named-mailboxes "iCloud/Sent"    +Sent
named-mailboxes "iCloud/Drafts"  +Drafts
named-mailboxes "iCloud/Trash"   +Trash
named-mailboxes "iCloud/Junk"    +Junk
