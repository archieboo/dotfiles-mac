# Gmail account settings
set realname  = "Chao Dai"
set from      = "daichao@gmail.com"
set status_format = " Gmail  ·  %f  ·  %r%m msgs%?n?  %n new?%?d?  %d del?%?t?  %t tag? %>  %?p?%p postponed  ? "

set folder    = "~/Mails/Gmail"
set spoolfile = "+INBOX"
set postponed = "+[Gmail]/Drafts"
set record    = "+[Gmail]/Sent Mail"

set sendmail = "msmtp --account=gmail"

unmailboxes *
source ~/.config/neomutt/notmuch
named-mailboxes "Gmail/INBOX"    +INBOX
named-mailboxes "Gmail/Sent"     +"[Gmail]/Sent Mail"
named-mailboxes "Gmail/Drafts"   +"[Gmail]/Drafts"
named-mailboxes "Gmail/Trash"    +"[Gmail]/Trash"
named-mailboxes "Gmail/Spam"     +"[Gmail]/Spam"
