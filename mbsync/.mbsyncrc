# iCloud (bajia@me.com)
IMAPAccount icloud
Host imap.mail.me.com
Port 993
User bajia@me.com
PassCmd "security find-internet-password -a bajia@me.com -s imap.mail.me.com -w"
AuthMechs LOGIN
TLSType IMAPS
CertificateFile /etc/ssl/cert.pem

IMAPStore icloud-remote
Account icloud

MaildirStore icloud-local
Subfolders Verbatim
Path ~/Mails/iCloud/
Inbox ~/Mails/iCloud/INBOX

Channel icloud-inbox
Far :icloud-remote:INBOX
Near :icloud-local:INBOX
Create Near
Expunge Both
SyncState *
MaxMessages 3000
ExpireUnread yes

Channel icloud-sent
Far :icloud-remote:Sent
Near :icloud-local:Sent
Create Near
Expunge Both
SyncState *
MaxMessages 200
ExpireUnread yes

Channel icloud-drafts
Far :icloud-remote:Drafts
Near :icloud-local:Drafts
Create Near
Expunge Both
SyncState *
MaxMessages 50
ExpireUnread yes

Channel icloud-trash
Far :icloud-remote:Trash
Near :icloud-local:Trash
Create Near
Expunge Both
SyncState *
MaxMessages 100
ExpireUnread yes

Channel icloud-junk
Far :icloud-remote:Junk
Near :icloud-local:Junk
Create Near
Expunge Both
SyncState *
MaxMessages 300
ExpireUnread yes

Group icloud
Channel icloud-inbox
Channel icloud-sent
Channel icloud-drafts
Channel icloud-trash
Channel icloud-junk


# Gmail (daichao@gmail.com)
IMAPAccount gmail
Host imap.gmail.com
Port 993
User daichao@gmail.com
PassCmd "security find-internet-password -a daichao@gmail.com -s imap.gmail.com -w"
AuthMechs LOGIN
TLSType IMAPS
CertificateFile /etc/ssl/cert.pem

IMAPStore gmail-remote
Account gmail

MaildirStore gmail-local
Subfolders Verbatim
Path ~/Mails/Gmail/
Inbox ~/Mails/Gmail/INBOX

Channel gmail-inbox
Far :gmail-remote:INBOX
Near :gmail-local:INBOX
Create Near
Expunge Both
SyncState *
MaxMessages 3000
ExpireUnread yes

Channel gmail-sent
Far :gmail-remote:"[Gmail]/Sent Mail"
Near :gmail-local:"[Gmail]/Sent Mail"
Create Near
Expunge Both
SyncState *
MaxMessages 200
ExpireUnread yes

Channel gmail-drafts
Far :gmail-remote:"[Gmail]/Drafts"
Near :gmail-local:"[Gmail]/Drafts"
Create Near
Expunge Both
SyncState *
MaxMessages 50
ExpireUnread yes

Channel gmail-trash
Far :gmail-remote:"[Gmail]/Trash"
Near :gmail-local:"[Gmail]/Trash"
Create Near
Expunge Both
SyncState *
MaxMessages 100
ExpireUnread yes

Channel gmail-spam
Far :gmail-remote:"[Gmail]/Spam"
Near :gmail-local:"[Gmail]/Spam"
Create Near
Expunge Both
SyncState *
MaxMessages 300
ExpireUnread yes

Group gmail
Channel gmail-inbox
Channel gmail-sent
Channel gmail-drafts
Channel gmail-trash
Channel gmail-spam
